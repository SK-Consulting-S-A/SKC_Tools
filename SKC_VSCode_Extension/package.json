{
  "name": "skc-vs-tools",
  "displayName": "SKC VS Tools",
  "description": "Applies the SKC preset: user settings (incl. MCP servers) and required extensions.",
  "version": "1.1.2",
  "publisher": "SKConsultingSA",
  "repository": {
    "type": "git",
    "url": "https://github.com/SK-Consulting-S-A/SKC_Tools"
  },
  "homepage": "https://www.skc.lu",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/SK-Consulting-S-A/SKC_Tools/issues"
  },
  "_comment": "Note: Extension visibility (public/private) is managed via VS Code Marketplace web UI. Extensions are private by default. To change visibility, visit: https://marketplace.visualstudio.com/manage/publishers/SKConsultingSA/extensions/skc-vs-tools/hub",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:al",
    "onCommand:skc.applyPresets",
    "onCommand:skc.configureMcpAuth",
    "onView:skc.translationsView"
  ],
  "main": "./out/extension.js",
  "icon": "assets/Small_Logo.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skc-tools",
          "title": "SKC Tools",
          "icon": "assets/skc-icon.svg"
        }
      ]
    },
    "views": {
      "skc-tools": [
        {
          "id": "skc.translationsView",
          "name": "Translations",
          "contextualTitle": "SKC Translations"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "skc.translationsView",
        "contents": "No translation files found.\n\nMake sure your workspace has a **Translations** folder with **.g.xlf** files.\n\n[Refresh](command:skc.refreshTranslations)"
      }
    ],
    "commands": [
      {
        "command": "skc.applyPresets",
        "title": "SKC: Apply Presets"
      },
      {
        "command": "skc.configureMcpAuth",
        "title": "SKC: Configure MCP Auth"
      },
      {
        "command": "skc.translateFile",
        "title": "Translate File",
        "icon": "$(play)"
      },
      {
        "command": "skc.refreshTranslations",
        "title": "Refresh Translations",
        "icon": "$(refresh)"
      },
      {
        "command": "skc.configureTranslationUrl",
        "title": "SKC: Configure Translation URL",
        "icon": "$(gear)"
      },
      {
        "command": "skc.createTranslationFile",
        "title": "Create Translation File",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "skc.refreshTranslations",
          "when": "view == skc.translationsView",
          "group": "navigation"
        },
        {
          "command": "skc.configureTranslationUrl",
          "when": "view == skc.translationsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "skc.translateFile",
          "when": "view == skc.translationsView && viewItem == xlfFile",
          "group": "inline"
        },
        {
          "command": "skc.translateFile",
          "when": "view == skc.translationsView && viewItem == sourceFile",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "SKC Presets",
      "properties": {
        "skc.skipInstalledExtensions": {
          "type": "boolean",
          "default": true,
          "description": "Skip reinstalling extensions that are already present."
        },
        "skc.presetFilePath": {
          "type": "string",
          "default": "presets/settings.json",
          "description": "Optional path to a JSON preset file. If set, the file is read on activation/command to overlay settings and extensions. Relative paths resolve from the first workspace folder."
        },
        "skc.mcpFilePath": {
          "type": "string",
          "default": "presets/mcp.json",
          "description": "Optional path to a JSON file that defines only MCP servers. If set, it replaces the built-in mcp.servers. Relative paths resolve from the first workspace folder. Special value: 'cursor-global' resolves to the global Cursor MCP file (~/.cursor/mcp.json)."
        },
        "skc.extensionsFilePath": {
          "type": "string",
          "default": "presets/extensions.json",
          "description": "Optional path to a JSON file that defines additional extensions to install. Unioned with the built-in list. Relative paths resolve from the first workspace folder."
        },
        "skc.showNewsOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Show news notification on VS Code startup, especially when a new version is detected."
        },
        "skc.autoOpenNewsPage": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the news page in full view on startup instead of showing a notification. Requires 'showNewsOnStartup' to be enabled."
        },
        "skc.newsFilePath": {
          "type": "string",
          "default": "presets/NEWS.md",
          "description": "Path to a markdown file containing news/updates. Shown on startup when enabled. Relative paths resolve from the extension folder or workspace."
        },
        "skc.azureFunctionUrl": {
          "type": "string",
          "default": "",
          "description": "URL of the Azure Translation Function endpoint (e.g., https://your-function.azurewebsites.net/api/github-webhook?mode=direct)."
        }
      }
    },
    "configurationDefaults": {
      "[al]": {
        "editor.defaultFormatter": "ms-dynamics-smb.al",
        "editor.formatOnSave": true
      }
    },
    "extensionDependencies": [
      "ms-dynamics-smb.al",
      "waldo.al-extension-pack",
      "usernamehw.errorlens",
      "GitHub.vscode-pull-request-github",
      "vstirbu.vscode-mermaid-preview",
      "idered.npm",
      "rasmus.al-var-helper",
      "BartPermentier.al-toolbox",
      "ms-azuretools.vscode-azurefunctions",
      "ms-azuretools.vscode-azureappservice",
      "ms-vscode.azure-account",
      "ms-vscode.vscode-typescript-next",
      "nabsolutions.nab-al-tools",
      "andrzejzwierzchowski.al-code-outline",
      "redhat.vscode-xml",
      "wbrakowski.al-navigator",
      "ms-vscode.PowerShell",
      "365businessdevelopment.365businessdev-alget"
    ],
    "extensionPack": [
      "ms-dynamics-smb.al",
      "waldo.al-extension-pack",
      "usernamehw.errorlens",
      "GitHub.vscode-pull-request-github",
      "vstirbu.vscode-mermaid-preview",
      "idered.npm",
      "rasmus.al-var-helper",
      "BartPermentier.al-toolbox",
      "ms-azuretools.vscode-azurefunctions",
      "ms-azuretools.vscode-azureappservice",
      "ms-vscode.azure-account",
      "ms-vscode.vscode-typescript-next",
      "nabsolutions.nab-al-tools",
      "andrzejzwierzchowski.al-code-outline",
      "redhat.vscode-xml",
      "wbrakowski.al-navigator",
      "ms-vscode.PowerShell",
      "365businessdevelopment.365businessdev-alget"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run sync:extensions && tsc -p ./",
    "sync:extensions": "node scripts/sync-extensions.js",
    "compile": "npm run sync:extensions && tsc -p ./",
    "package": "npm run sync:extensions && tsc -p ./ && vsce package",
    "publish": "npm run compile && node scripts/publish.js",
    "publish:patch": "npm run compile && node scripts/publish.js patch",
    "publish:minor": "npm run compile && node scripts/publish.js minor",
    "publish:major": "npm run compile && node scripts/publish.js major",
    "publish:prerelease": "npm run compile && node scripts/publish.js --pre-release",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/vsce": "^2.32.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.3"
  }
}
