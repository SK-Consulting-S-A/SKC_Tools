{
  "name": "skc-extension-app",
  "displayName": "SKC Extension App",
  "description": "Applies the SKC preset: user settings (incl. MCP servers) and required extensions.",
  "version": "0.1.0",
  "publisher": "skc",
  "repository": {
    "type": "git",
    "url": "https://github.com/skc/skc-vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:al",
    "onCommand:skc.applyPresets",
    "onCommand:skc.configureMcpAuth",
    "onCommand:skc.runAlGo"
  ],
  "main": "./out/extension.js",
  "icon": "assets/Small_Logo.gif",
  "contributes": {
    "commands": [
      {
        "command": "skc.applyPresets",
        "title": "SKC: Apply Presets"
      },
      {
        "command": "skc.configureMcpAuth",
        "title": "SKC: Configure MCP Auth"
      },
      {
        "command": "skc.runAlGo",
        "title": "SKC: GO!"
      }
    ],
    "configuration": {
      "title": "SKC Presets",
      "properties": {
        "skc.applyOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Apply SKC presets automatically when the extension activates."
        },
        "skc.skipInstalledExtensions": {
          "type": "boolean",
          "default": true,
          "description": "Skip reinstalling extensions that are already present."
        },
        "skc.presetFilePath": {
          "type": "string",
          "default": "presets/settings.json",
          "description": "Optional path to a JSON preset file. If set, the file is read on activation/command to overlay settings and extensions. Relative paths resolve from the first workspace folder."
        },
        "skc.mcpFilePath": {
          "type": "string",
          "default": "presets/mcp.json",
          "description": "Optional path to a JSON file that defines only MCP servers. If set, it replaces the built-in mcp.servers. Relative paths resolve from the first workspace folder."
        },
        "skc.extensionsFilePath": {
          "type": "string",
          "default": "presets/extensions.json",
          "description": "Optional path to a JSON file that defines additional extensions to install. Unioned with the built-in list. Relative paths resolve from the first workspace folder."
        },
        "skc.alGoCommand": {
          "type": "string",
          "default": "al-go",
          "description": "Command to run when invoking 'SKC: GO!'. Runs in the workspace root."
        },
        "skc.alGoRunInTerminal": {
          "type": "boolean",
          "default": false,
          "description": "Run the SKC: GO! command in a terminal (true) or invoke it as a VS Code command ID via commands.executeCommand (false). Command-like IDs (e.g., al.go) run as a command when this is false."
        }
      }
    },
    "configurationDefaults": {
      "[al]": {
        "editor.defaultFormatter": "ms-dynamics-smb.al",
        "editor.formatOnSave": true
      }
    },
    "extensionDependencies": [
      "ms-dynamics-smb.al",
      "waldo.al-extension-pack",
      "usernamehw.errorlens",
      "GitHub.vscode-pull-request-github",
      "vstirbu.vscode-mermaid-preview",
      "idered.npm",
      "rasmus.al-var-helper",
      "BartPermentier.al-toolbox",
      "ms-azuretools.vscode-azurefunctions",
      "ms-azuretools.vscode-azureappservice",
      "ms-vscode.azure-account",
      "ms-vscode.vscode-typescript-next",
      "nabsolutions.nab-al-tools",
      "andrzejzwierzchowski.al-code-outline",
      "redhat.vscode-xml",
      "wbrakowski.al-navigator",
      "ms-vscode.PowerShell",
      "365businessdevelopment.365businessdev-alget"
    ],
    "extensionPack": [
      "ms-dynamics-smb.al",
      "waldo.al-extension-pack",
      "usernamehw.errorlens",
      "GitHub.vscode-pull-request-github",
      "vstirbu.vscode-mermaid-preview",
      "idered.npm",
      "rasmus.al-var-helper",
      "BartPermentier.al-toolbox",
      "ms-azuretools.vscode-azurefunctions",
      "ms-azuretools.vscode-azureappservice",
      "ms-vscode.azure-account",
      "ms-vscode.vscode-typescript-next",
      "nabsolutions.nab-al-tools",
      "andrzejzwierzchowski.al-code-outline",
      "redhat.vscode-xml",
      "wbrakowski.al-navigator",
      "ms-vscode.PowerShell",
      "365businessdevelopment.365businessdev-alget"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run sync:extensions && tsc -p ./",
    "sync:extensions": "node scripts/sync-extensions.js",
    "compile": "npm run sync:extensions && tsc -p ./",
    "package": "npm run sync:extensions && tsc -p ./ && vsce package",
    "publish": "npm run compile && node scripts/publish.js",
    "publish:patch": "npm run compile && node scripts/publish.js patch",
    "publish:minor": "npm run compile && node scripts/publish.js minor",
    "publish:major": "npm run compile && node scripts/publish.js major",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/vsce": "^2.32.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.3"
  }
}
